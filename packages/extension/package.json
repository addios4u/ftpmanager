{
  "name": "ftpmanager",
  "displayName": "FTPManager",
  "description": "FTP/SFTP client for VS Code - connect, browse, edit and transfer files on remote servers",
  "version": "1.0.0",
  "publisher": "addios4u",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/addios4u/ftpmanager.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1a3a5c",
    "theme": "dark"
  },
  "categories": ["Other"],
  "keywords": ["ftp", "sftp", "ftps", "remote", "file transfer", "ssh"],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "ftpmanager.servers",
          "name": "%viewName.servers%"
        }
      ]
    },
    "commands": [
      {
        "command": "ftpmanager.addServer",
        "title": "%command.addServer%",
        "icon": "$(add)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.editServer",
        "title": "%command.editServer%",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.deleteServer",
        "title": "%command.deleteServer%",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.connect",
        "title": "%command.connect%",
        "icon": "$(plug)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.disconnect",
        "title": "%command.disconnect%",
        "icon": "$(debug-disconnect)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.refresh",
        "title": "%command.refresh%",
        "icon": "$(refresh)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.uploadFile",
        "title": "%command.uploadFile%",
        "icon": "$(cloud-upload)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.downloadFile",
        "title": "%command.downloadFile%",
        "icon": "$(cloud-download)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.downloadFolder",
        "title": "%command.downloadFolder%",
        "icon": "$(cloud-download)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.newFolder",
        "title": "%command.newFolder%",
        "icon": "$(folder-opened)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.rename",
        "title": "%command.rename%",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.deleteRemote",
        "title": "%command.deleteRemote%",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.copyRemotePath",
        "title": "%command.copyRemotePath%",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.uploadToServer",
        "title": "%command.uploadToServer%",
        "icon": "$(cloud-upload)",
        "category": "%category.ftpManager%"
      },
      {
        "command": "ftpmanager.openRemoteFile",
        "title": "%command.openRemoteFile%",
        "category": "%category.ftpManager%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ftpmanager.addServer",
          "when": "view == ftpmanager.servers",
          "group": "navigation"
        },
        {
          "command": "ftpmanager.refresh",
          "when": "view == ftpmanager.servers",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ftpmanager.connect",
          "when": "view == ftpmanager.servers && viewItem == server-disconnected",
          "group": "inline"
        },
        {
          "command": "ftpmanager.disconnect",
          "when": "view == ftpmanager.servers && viewItem == server-connected",
          "group": "inline"
        },
        {
          "command": "ftpmanager.refresh",
          "when": "view == ftpmanager.servers && viewItem =~ /server-connected|directory/",
          "group": "inline"
        },
        {
          "command": "ftpmanager.uploadFile",
          "when": "view == ftpmanager.servers && viewItem =~ /server-connected|directory/",
          "group": "inline"
        },
        {
          "command": "ftpmanager.editServer",
          "when": "view == ftpmanager.servers && viewItem =~ /^server/",
          "group": "1_server@1"
        },
        {
          "command": "ftpmanager.deleteServer",
          "when": "view == ftpmanager.servers && viewItem =~ /^server/",
          "group": "1_server@2"
        },
        {
          "command": "ftpmanager.connect",
          "when": "view == ftpmanager.servers && viewItem == server-disconnected",
          "group": "1_server@0"
        },
        {
          "command": "ftpmanager.disconnect",
          "when": "view == ftpmanager.servers && viewItem == server-connected",
          "group": "1_server@0"
        },
        {
          "command": "ftpmanager.uploadFile",
          "when": "view == ftpmanager.servers && viewItem =~ /server-connected|directory/",
          "group": "2_transfer@1"
        },
        {
          "command": "ftpmanager.newFolder",
          "when": "view == ftpmanager.servers && viewItem =~ /server-connected|directory/",
          "group": "2_transfer@3"
        },
        {
          "command": "ftpmanager.downloadFile",
          "when": "view == ftpmanager.servers && viewItem == file",
          "group": "2_transfer@1"
        },
        {
          "command": "ftpmanager.downloadFolder",
          "when": "view == ftpmanager.servers && viewItem == directory",
          "group": "2_transfer@2"
        },
        {
          "command": "ftpmanager.rename",
          "when": "view == ftpmanager.servers && viewItem =~ /^file$|^directory$/",
          "group": "3_edit@1"
        },
        {
          "command": "ftpmanager.deleteRemote",
          "when": "view == ftpmanager.servers && viewItem =~ /^file$|^directory$/",
          "group": "3_edit@2"
        },
        {
          "command": "ftpmanager.copyRemotePath",
          "when": "view == ftpmanager.servers && viewItem =~ /^file$|^directory$/",
          "group": "4_misc@1"
        }
      ],
      "explorer/context": [
        {
          "command": "ftpmanager.uploadToServer",
          "group": "navigation@99"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepackage": "pnpm run build",
    "package": "vsce package --no-dependencies -o ../../out/ftpmanager.vsix",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "@ftpmanager/shared": "workspace:*",
    "basic-ftp": "^5.0.5",
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ssh2-sftp-client": "^9.0.4",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "vitest": "^2.0.0"
  }
}

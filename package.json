{
  "name": "ftpmanager-root",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @ftpmanager/shared build && pnpm --filter @ftpmanager/webview-ui build && pnpm --filter ftpmanager build",
    "watch": "pnpm --filter ftpmanager watch",
    "typecheck": "pnpm -r typecheck",
    "package": "pnpm --filter ftpmanager package",
    "publish:vsce": "pnpm --filter ftpmanager publish:vsce",
    "publish:ovsx": "pnpm --filter ftpmanager publish:ovsx",
    "publish:all": "pnpm --filter ftpmanager publish:all"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "ssh2",
      "cpu-features",
      "@vscode/vsce-sign",
      "keytar"
    ]
  },
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6"
}
